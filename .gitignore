# Repo-root ignores. Each app/package has its own .gitignore for tool-specific paths.

# dependencies (workspaces hoist here)
node_modules/

# secrets / keys
*.pem
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# local env
.env
.env*.local

# typescript / tooling
*.tsbuildinfo

# debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
