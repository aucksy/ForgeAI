# dependencies (hoisted to the workspace root, but ignore any local one too)
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Metro
.metro-health-check*

# Native — iOS unused; ANDROID source is committed (built in CI), so track its
# source but ignore build outputs, local config and ALL keystores.
/ios
.kotlin/
android/build/
android/app/build/
android/.gradle/
android/.cxx/
android/.kotlin/
android/local.properties
android/app/release.keystore
*.keystore
*.orig.*
# the standard Android debug keystore is NOT a secret and CI needs it for the
# secret-less debug-signing fallback:
!android/app/debug.keystore

# typescript
*.tsbuildinfo
